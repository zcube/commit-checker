{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": ["before 9am on monday"],
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "matchCategories": [
        "golang"
      ],
      "postUpdateOptions": [
        "gomodTidy"
      ]
    },
    {
      "matchManagers": ["gomod"],
      "matchDepTypes": [
        "indirect"
      ],
      "groupName": "Go indirect dependencies",
      "automerge": true
    },
    {
      "matchManagers": ["gomod"],
      "groupName": "charmbracelet",
      "matchPackageNames": [
        "/^github.com/charmbracelet//"
      ]
    },
    {
      "matchManagers": ["gomod"],
      "groupName": "golang.org/x",
      "matchPackageNames": [
        "/^golang.org/x//"
      ]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "automerge": true
    }
  ]
}
